## Required
# Strong random secret (used to sign session cookies)
SECRET_KEY=change-me-to-a-long-random-string

## Optional: session cookie policy
# "lax" (default), "strict", "none"
SESSION_SAMESITE=lax
# Set to 1 when running behind HTTPS (recommended in production)
SESSION_HTTPS_ONLY=0

## Optional (dev only): create test admin on DB init
# CREATE_TEST_ADMIN=1
# TEST_ADMIN_PASSWORD=change-me

## Optional: VK integration (for auto-posting)
# VK_ACCESS_TOKEN=put-your-token-here
# VK_OWNER_ID=-123456789
# VK_API_VERSION=5.199

## Optional: VK stats collection (background)
# Poll interval for background collector (seconds)
# VK_STATS_POLL_SECONDS=600
# How many recent VK publications to refresh each run
# VK_STATS_LIMIT=50
# How many days back to consider publications for refresh
# VK_STATS_LOOKBACK_DAYS=14

## Optional: Google Sheets integration (for the home page)
# Spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
# GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
#
# A1 range to read (defaults to A1:Z50)
# GOOGLE_SHEETS_RANGE=Sheet1!A1:Z50
#
# Option A (public sheet): API key
# GOOGLE_SHEETS_API_KEY=your-google-api-key
#
# Option B (private sheet): Service Account JSON file path (do NOT commit the json)
# GOOGLE_SHEETS_SERVICE_ACCOUNT_FILE=secrets/service-account.json

