## Required
# Strong random secret (used to sign session cookies)
SECRET_KEY=change-me-to-a-long-random-string

## Optional: session cookie policy
# "lax" (default), "strict", "none"
SESSION_SAMESITE=lax
# Set to 1 when running behind HTTPS (recommended in production)
SESSION_HTTPS_ONLY=0

## Optional (dev only): create test admin on DB init
# CREATE_TEST_ADMIN=1
# TEST_ADMIN_PASSWORD=change-me

